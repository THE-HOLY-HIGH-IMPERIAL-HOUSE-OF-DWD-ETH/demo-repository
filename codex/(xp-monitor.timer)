[Unit]
Description=Trigger XP Monitor every 60 seconds

[Timer]
OnBootSec=1min
OnUnitActiveSec=60sec
Unit=xp-monitor.service

[Install]
WantedBy=timers.target

# Move and secure files
sudo mv xp-monitor.service /etc/systemd/system/
sudo mv xp-monitor.timer /etc/systemd/system/
sudo chmod 644 /etc/systemd/system/xp-monitor.*

# Activate Imperial Watchdog
sudo systemctl daemon-reload
sudo systemctl enable --now xp-monitor.timer

# Verification of Finality
sudo systemctl list-timers --all | grep xp-monitor
