target_file: "/infrastructure/reverse-proxy.conf"
format: "NGINX Reverse Proxy Configuration Suite"
configuration_block: |
  server {
      listen 443 ssl http2;
      server_name api.xp.reserve;

      # Enforcement of TLS Transport Layer Privacy Safety Shields
      ssl_certificate /etc/ssl/certs/public-key-infrastructure.pem;
      ssl_certificate_key /etc/ssl/private/production-private-key.key;
      ssl_protocols TLSv1.2 TLSv1.3;
      ssl_ciphers HIGH:!aNULL:!MD5;

      # Advanced Web Application Security Response Headers
      add_header X-Frame-Options "DENY" always;
      add_header X-Content-Type-Options "nosniff" always;
      add_header Content-Security-Policy "default-src 'none'; sandbox;" always;
      add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

      # Automated Traffic Rate-Limiting Buffer to Prevent Gateway Saturation
      limit_req_zone $binary_remote_addr zone=gateway_limit:10m rate=10r/s;
      limit_req zone=gateway_limit burst=20 nodelay;

      # Cryptographic Identity & Context Routing Paths
      location / {
          proxy_pass http://soverain-api-gateway:8080;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
          proxy_set_header X-Forwarded-Proto $scheme;
      }
  }
